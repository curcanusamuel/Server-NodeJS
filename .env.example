PORT=3000

# Preferred: provide one full Postgres connection string
DB_CONNECTION_MODE=direct
# Options: direct | pooler
DB_SSL_REJECT_UNAUTHORIZED=false
#
# Linux with IPv6 direct host:
# DATABASE_URL_DIRECT=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
#
# macOS/Windows with IPv4-friendly pooler:
# DATABASE_URL_POOLER=postgresql://postgres.<project-ref>:<PASSWORD>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
#
# Legacy alias (optional):
# SUPABASE_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
#
# If PASSWORD contains URL-reserved chars like # or @, encode them (e.g. # -> %23)

# Fallback split variables (used only if no connection URL variable is set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ids_clinic
DB_USER=postgres
DB_PASSWORD=
