PORT=3000

# Preferred: provide one full Postgres connection string
# Linux with IPv6 direct host:
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# macOS/Windows with IPv4-friendly pooler:
# DATABASE_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require

# Fallback split variables (used only if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ids_clinic
DB_USER=postgres
DB_PASSWORD=
